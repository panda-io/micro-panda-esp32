@raw("#include \"freertos/FreeRTOS.h\"")
@raw("#include \"freertos/task.h\"")

// pdMS_TO_TICKS is a macro — wrap it in a plain C helper so @extern can bind to it.
@raw("static inline void __mp_delay_ms(int32_t ms) { vTaskDelay(pdMS_TO_TICKS(ms)); }")

// Delay by raw FreeRTOS ticks.
@extern("vTaskDelay")
fun delay(ticks: i32)

// Delay by milliseconds. Converts via pdMS_TO_TICKS (correct for any tick rate).
@extern("__mp_delay_ms")
fun delay_ms(ms: i32)
